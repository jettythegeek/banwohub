APP_NAME="Banwolaw Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://api.banwohub.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Platform currency (invoices, time tracking, expenses, reports)
APP_CURRENCY=USD
APP_CURRENCY_SYMBOL=$
APP_CURRENCY_LOCALE=en-US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=banwohub
# Use your XAMPP MySQL user (e.g. root or a dedicated user like jetty)
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.banwohub.test
SANCTUM_STATEFUL_DOMAINS=banwohub.test,api.banwohub.test

FRONTEND_URL=http://banwohub.test
PASSWORD_RESET_FRONTEND_URL=http://banwohub.test/reset-password
CORS_ALLOWED_ORIGINS=http://banwohub.test,http://localhost:3000,http://127.0.0.1:3000

# Payment gateways (sandbox/test keys — leave empty to disable online checkout)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=

BROADCAST_CONNECTION=reverb

REVERB_APP_ID=banwohub
REVERB_APP_KEY=banwohub-reverb-key
REVERB_APP_SECRET=banwohub-reverb-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8085
REVERB_SCHEME=http
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@banwolaw.com"
MAIL_FROM_NAME="${APP_NAME}"

# AI service (separate deployable — see ai-service/)
# When no org-level provider is active, Laravel calls the AI service below (requires AI_OPENAI_API_KEY in ai-service/.env).
AI_SERVICE_URL=http://127.0.0.1:3100
AI_SERVICE_KEY=banwohub-ai-dev-key
AI_STUB_MODE=false
AI_RATE_LIMIT_PER_MINUTE=30
AI_PUBLIC_RATE_LIMIT_PER_MINUTE=10
# AI_PUBLIC_ORGANIZATION_ID=1

# Default models for org AI provider settings (OpenAI, Anthropic, Google AI, Deepseek)
AI_OPENAI_DEFAULT_MODEL=gpt-4o-mini
AI_ANTHROPIC_DEFAULT_MODEL=claude-3-5-haiku-20241022
AI_GOOGLE_DEFAULT_MODEL=gemini-2.0-flash
AI_DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# External integrations (Settings → Integrations — leave empty to show as disabled)
# TWILIO_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM=
# WHATSAPP_BUSINESS_TOKEN=
# GOOGLE_DOCS_CLIENT_ID=
# GOOGLE_DOCS_CLIENT_SECRET=
# GOOGLE_DOCS_REFRESH_TOKEN=
# COURT_EFILING_API_KEY=
# COURT_EFILING_BASE_URL=
# COURT_EFILING_PROVIDER=

# OnlyOffice Document Server (Slice 5 — docker compose -f docker-compose.onlyoffice.yml up -d)
# ONLYOFFICE_URL=http://localhost:8080
# ONLYOFFICE_JWT_SECRET=banwohub-onlyoffice-dev
# ONLYOFFICE_FILE_URL_TTL=120

# Seeder passwords — override in .env (never commit real passwords)
SEED_ADMIN_PASSWORD=ChangeMe123!
SEED_SYSADMIN_PASSWORD=ChangeMe123!
